{
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/next",
    "ultracite/biome/tanstack",
    "ultracite/biome/vitest"
  ],
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "!**/.next",
      "!**/dist",
      "!**/.turbo",
      "!**/dev-dist",
      "!**/.zed",
      "!**/.vscode",
      "!**/routeTree.gen.ts",
      "!**/.source",
      "!apps/www/public/r"
    ]
  },
  "linter": {
    "rules": {
      "style": {
        "noEnum": "off",
        "noNamespace": "off",
        "noExportedImports": "off",
        "useConsistentArrayType": "off",
        "useFilenamingConvention": "off",
        "useUnifiedTypeSignatures": "off",
        "useReadonlyClassProperties": "off",
        "useConsistentTypeDefinitions": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noNamespaceImport": "off"
      },
      "nursery": "off",
      "suspicious": {
        "noConsole": "off",
        "noExplicitAny": "off",
        "noBitwiseOperators": "off",
        "noDuplicateProperties": "off",
        "noShadowRestrictedNames": "off",
        "noDuplicateCustomProperties": "off",
        "useAdjacentOverloadSignatures": "off"
      },
      "a11y": {
        "useSemanticElements": "off",
        "noNoninteractiveElementInteractions": "off"
      }
    }
  }
}
